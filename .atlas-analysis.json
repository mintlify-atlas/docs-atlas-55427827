{
  "projectType": "saas",
  "projectName": "Personal Finance Web",
  "projectDescription": "A personal finance management web app for tracking income, expenses, and categories with charts, filters, and dark mode support.",
  "theme": "almond",
  "primaryColor": "#5b5ea6",
  "lightColor": "#e8e9f5",
  "darkColor": "#2d2f6b",
  "navigation": {
