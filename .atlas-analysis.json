              "architecture/state-management"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Transactions",
            "pages": [
              "api-reference/transactions/get-transactions",
              "api-reference/transactions/create-transaction",
              "api-reference/transactions/update-transaction",
              "api-reference/transactions/delete-transaction"
            ]
          },
          {
