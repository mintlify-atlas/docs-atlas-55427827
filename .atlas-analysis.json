  "keyFeatures": [
    "Financial dashboard with income/expense balance cards and trend comparisons",
    "Interactive charts powered by ECharts showing spending by category",
    "Transaction management with full CRUD operations and filtering",
    "Category management with custom categories for organizing transactions",
    "Month/year filters for viewing historical financial data",
    "Dark mode toggle with system preference detection and localStorage persistence",
    "User profile customization with avatar selection and name editing",
    "Protected routes with session-based authentication via localStorage",
    "Lazy-loaded pages with Suspense for optimized performance",
    "Responsive design with Tailwind CSS and mobile-friendly layouts"
  ],
  "publicApiSurface": [
    "GET /api/transactions",
    "POST /api/transactions",
    "PATCH /api/transactions/:id",
    "DELETE /api/transactions/:id",
    "GET /api/transactions/years",
    "GET /api/categories",
    "POST /api/categories",
    "PUT /api/categories/:id",
    "DELETE /api/categories/:id",
    "GET /api/stats/monthly",
    "GET /api/stats/top-categories",
    "GET /api/stats/by-category"
  ]
}
